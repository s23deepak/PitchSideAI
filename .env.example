# ── Environment ──────────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=false

# ── AWS Configuration ────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here

# ── API Server ────────────────────────────────────────────────────────────────
PORT=8080
HOST=0.0.0.0
LOG_LEVEL=info
USE_JSON_LOGS=true
LOG_FILE=logs/pitchside.log

# ── Amazon Bedrock Models ────────────────────────────────────────────────────
LIVE_AUDIO_MODEL=amazon.nova-sonic-v2:0
VISION_MODEL=amazon.nova-lite-v2:0
RESEARCH_MODEL=amazon.nova-pro-v2:0
EMBEDDING_MODEL=amazon.titan-embed-text-v2:0

# ── OpenSearch (RAG) ─────────────────────────────────────────────────────────
OPENSEARCH_ENDPOINT=your-opensearch-endpoint.us-east-1.aoss.amazonaws.com
OPENSEARCH_INDEX=pitchside-match-notes
OPENSEARCH_AUTH=aws_sig4

# ── DynamoDB ─────────────────────────────────────────────────────────────────
DYNAMODB_TABLE_NAME=PitchSideMatchEvents
DYNAMODB_REGION=us-east-1

# ── Bedrock AgentCore ────────────────────────────────────────────────────────
BEDROCK_AGENT_ID=your-agent-id
BEDROCK_AGENT_ALIAS_ID=your-agent-alias-id

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_RPM=100
RATE_LIMIT_BURST=10

# ── Concurrency ──────────────────────────────────────────────────────────────
MAX_CONCURRENT_TASKS=20
REQUEST_TIMEOUT_SECONDS=300

# ── Audio Configuration ─────────────────────────────────────────────────────
AUDIO_SAMPLE_RATE=16000
FRAME_SAMPLE_INTERVAL=5
NATIVE_VIDEO_WINDOW_SECONDS=3.0
NATIVE_VIDEO_WINDOW_OVERLAP_SECONDS=0.75
NATIVE_VIDEO_MAX_WINDOWS=6

# ── CORS Configuration ──────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Frontend Video Fallback Defaults ────────────────────────────────────────
# Build-time defaults for TacticalOverlay when running the frontend with Vite.
# Valid presets: balanced, high-detail, max-detail
# Valid modes: uniform, adaptive
VITE_FALLBACK_VIDEO_SAMPLING_PRESET=high-detail
VITE_FALLBACK_VIDEO_SAMPLING_MODE=adaptive

# ── LLM Backend ─────────────────────────────────────────────────────────────
# Options: "bedrock" (default), "ollama", "openai", "vllm"
LLM_BACKEND=bedrock
VISION_LLM_BACKEND=vllm
COMMENTARY_NOTES_LLM_BACKEND=ollama

# Recommended deployment profiles:
# - Cloud production: LLM_BACKEND=bedrock
# - Self-hosted:     LLM_BACKEND=vllm with Qwen/Qwen2.5-VL-7B-Instruct
# - Lightweight local: LLM_BACKEND=ollama with qwen2.5:3b + qwen2.5vl:3b
# - Mixed local:     COMMENTARY_NOTES_LLM_BACKEND=ollama and VISION_LLM_BACKEND=vllm

# ── Ollama (Local) ──────────────────────────────────────────────────────────
# Only needed when LLM_BACKEND=ollama
# Suggested lightweight local profile:
# OLLAMA_MODEL=qwen2.5:3b
# OLLAMA_VISION_MODEL=qwen2.5vl:3b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_VISION_MODEL=llama3.2-vision
OLLAMA_EMBED_MODEL=nomic-embed-text

# ── OpenAI ──────────────────────────────────────────────────────────────────
# Only needed when LLM_BACKEND=openai
OPENAI_API_KEY=your-openai-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small

# ── vLLM (Self-Hosted) ─────────────────────────────────────────────────────
# Only needed when LLM_BACKEND=vllm
# Suggested self-hosted video profile:
# VLLM_MODEL=Qwen/Qwen2.5-7B-Instruct
# VLLM_VISION_MODEL=Qwen/Qwen2.5-VL-7B-Instruct
# Native-video retries: larger clips can be re-sent as overlapping native windows
VLLM_BASE_URL=http://localhost:8000
VLLM_MODEL=your-model-name
VLLM_VISION_MODEL=Qwen/Qwen2.5-VL-3B-Instruct-AWQ
VLLM_EMBED_MODEL=your-embed-model

# ── External Sports/Search APIs ─────────────────────────────────────────────
# Tavily Search (web search for bios, news, weather, storylines)
# Get a key at https://app.tavily.com
TAVILY_API_KEY=your-tavily-key-here

# football-data.org (standings, H2H, squad data)
# Get a key at https://www.football-data.org/client/register
FOOTBALL_DATA_API_KEY=your-football-data-key-here

# OpenWeatherMap (match-day weather — optional, Tavily used as primary)
OPENWEATHERMAP_API_KEY=your-openweathermap-key-here